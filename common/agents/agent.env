# Pick a UTF-8 locale that exists on the current machine. Minimal containers
# often only provide C.UTF-8, and tmux needs the locale before it starts.
__dotfiles_pick_utf8_locale() {
  if command -v locale >/dev/null 2>&1; then
    __dotfiles_avail_locales="$(locale -a 2>/dev/null)"
    for __dotfiles_locale in en_US.UTF-8 en_US.utf8 C.UTF-8 C.utf8; do
      case "$__dotfiles_avail_locales" in
        *"$__dotfiles_locale"*) printf '%s' "$__dotfiles_locale"; return 0 ;;
      esac
    done
  fi

  printf '%s' C.UTF-8
}

__dotfiles_utf8_locale="$(__dotfiles_pick_utf8_locale)"
export LANG="$__dotfiles_utf8_locale"
export LC_CTYPE="$__dotfiles_utf8_locale"
unset __dotfiles_utf8_locale __dotfiles_locale __dotfiles_avail_locales
unset -f __dotfiles_pick_utf8_locale 2>/dev/null || true

export PATH="$HOME/.local/bin:$HOME/.opencode/bin:$PATH"

# Pi coding agent: extended prompt cache (Anthropic: 1h, OpenAI: 24h).
export PI_CACHE_RETENTION=long

case "${DOTFILE_SYSTEM_TYPE:-}" in
  macos|codespaces|bpdev)
    export NPM_CONFIG_PREFIX="${NPM_CONFIG_PREFIX:-$HOME/.local}"
    ;;
esac

# Share global AGENTS.md with GitHub Copilot CLI. Copilot discovers
# ~/.agents/skills automatically; AGENTS.md needs this path.
__dotfiles_agent_instructions_dir="$HOME/.agents"
if [ -f "$__dotfiles_agent_instructions_dir/AGENTS.md" ]; then
  case ",${COPILOT_CUSTOM_INSTRUCTIONS_DIRS:-}," in
    *,"$__dotfiles_agent_instructions_dir",*) ;;
    *) export COPILOT_CUSTOM_INSTRUCTIONS_DIRS="$__dotfiles_agent_instructions_dir${COPILOT_CUSTOM_INSTRUCTIONS_DIRS:+,$COPILOT_CUSTOM_INSTRUCTIONS_DIRS}" ;;
  esac
fi
unset __dotfiles_agent_instructions_dir

if [ -z "${GITHUB_TOKEN:-}" ] && command -v gh >/dev/null 2>&1; then
  __dotfiles_github_token="$(gh auth token 2>/dev/null || true)"
  if [ -n "$__dotfiles_github_token" ]; then
    export GITHUB_TOKEN="$__dotfiles_github_token"
  fi
  unset __dotfiles_github_token
fi
