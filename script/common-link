#!/usr/bin/env bash
#
# Adds or removes a topic from a system manifest.

set -e

add=false
remove=false

case $1 in
  add)
    echo "Adding $2 to $3"
    add=true
    ;;
  remove)
    echo "Removing $2 from $3"
    remove=true
    ;;
  *)
    echo "Usage: $0 {add|remove} git macos"
    exit 1
    ;;
esac

cd "$(dirname "$0")/.."

manifest="systems/$3"
topic="$2"
case "$topic" in
  */*) ;;
  *) topic="common/$topic" ;;
esac

if [ ! -f "$manifest" ] ; then
  echo "$manifest does not exist. Exiting."
  exit 1
fi

if [ ! -d "$topic" ] ; then
  echo "$topic is not a directory or does not exist. Exiting."
  exit 1
fi

if [ "$add" = true ] ; then
  if grep -qxF "$topic" "$manifest" ; then
    echo "$topic already exists in $manifest. Skipping."
  else
    printf '%s\n' "$topic" >> "$manifest"
  fi
fi

if [ "$remove" = true ] ; then
  if grep -qxF "$topic" "$manifest" ; then
    tmp="$(mktemp)"
    grep -vxF "$topic" "$manifest" > "$tmp" || true
    mv "$tmp" "$manifest"
  else
    echo "$topic is not in $manifest. Skipping."
  fi
fi
