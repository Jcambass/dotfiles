#!/usr/bin/env bash
#
# bootstrap installs things.

cd "$(dirname "$0")/.."
DOTFILES_ROOT=$(pwd -P)

if ! [ -d $HOME/.dotfiles ]; then
  echo "Linking dotfiles from $DOTFILES_ROOT to $HOME/.dotfiles"
  ln -sf $DOTFILES_ROOT $HOME/.dotfiles
fi

bootstrap_warnings=()
linked_count=0
already_linked_count=0
skipped_count=0
overwritten_count=0
backed_up_count=0
install_count=0

supports_color () {
  [ -t 1 ] && [ -z "${NO_COLOR:-}" ]
}

supports_warning_color () {
  [ -t 2 ] && [ -z "${NO_COLOR:-}" ]
}

info () {
  printf "\r  [ \033[00;34m..\033[0m ] %s\n" "$1"
}

warn () {
  local message="$1"
  bootstrap_warnings+=("$message")

  if supports_warning_color; then
    printf "\r  [ \033[00;33mWARN\033[0m ] %s\n" "$message" >&2
  else
    printf "\r  [ WARN ] %s\n" "$message" >&2
  fi
}

success () {
  printf "\r\033[2K  [ \033[00;32mOK\033[0m ] %s\n" "$1"
}

fail () {
  printf "\r\033[2K  [\033[0;31mFAIL\033[0m] %s\n" "$1"
  echo ''
  exit 1
}

usage () {
  cat <<'USAGE'
Usage: script/bootstrap [options]

Options:
  -f, --force      overwrite existing conflicting files
      --backup     move existing conflicting files to *.backup
      --no-install skip install.sh scripts
  -h, --help       show this help

By default, bootstrap never prompts and skips conflicting files.
USAGE
}

print_summary () {
  local warning

  if supports_color; then
    printf "\r  [ \033[00;34m..\033[0m ] bootstrap summary: %s linked, %s already linked, %s skipped, %s overwritten, %s backed up, %s install scripts\n" \
      "$linked_count" "$already_linked_count" "$skipped_count" "$overwritten_count" "$backed_up_count" "$install_count"
  else
    printf "\r  [ .. ] bootstrap summary: %s linked, %s already linked, %s skipped, %s overwritten, %s backed up, %s install scripts\n" \
      "$linked_count" "$already_linked_count" "$skipped_count" "$overwritten_count" "$backed_up_count" "$install_count"
  fi

  if [ "${#bootstrap_warnings[@]}" -eq 0 ]; then
    return 0
  fi

  if supports_warning_color; then
    printf "\r  [ \033[00;33mWARN\033[0m ] %s warning(s) during bootstrap:\n" "${#bootstrap_warnings[@]}" >&2
  else
    printf "\r  [ WARN ] %s warning(s) during bootstrap:\n" "${#bootstrap_warnings[@]}" >&2
  fi

  for warning in "${bootstrap_warnings[@]}"; do
    printf "    - %s\n" "$warning" >&2
  done
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    -f|--force|--overwrite)
      DOTFILES_OVERWRITE_CONFLICTS=1
      ;;
    --backup)
      DOTFILES_BACKUP_CONFLICTS=1
      ;;
    --no-install|--skip-installs)
      DOTFILES_SKIP_INSTALLS=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      fail "Unknown option: $1"
      ;;
  esac
  shift
done

link_file () {
  local src=$1 dst=$2

  local currentSrc=

  if [ -f "$dst" -o -d "$dst" -o -L "$dst" ]
  then
    currentSrc="$(readlink "$dst" 2>/dev/null || true)"

    if [ "$currentSrc" == "$src" ]
    then
      already_linked_count=$((already_linked_count + 1))
      return 0
    fi

    if [ "$overwrite_all" == "true" ]
    then
      rm -rf "$dst"
      overwritten_count=$((overwritten_count + 1))
      success "removed $dst"
    elif [ "$backup_all" == "true" ]
    then
      mv "$dst" "${dst}.backup"
      backed_up_count=$((backed_up_count + 1))
      success "moved $dst to ${dst}.backup"
    else
      skipped_count=$((skipped_count + 1))
      warn "skipped $dst; exists and is not linked to $src"
      return 0
    fi
  fi

  if ln -s "$1" "$2"; then
    linked_count=$((linked_count + 1))
    success "linked $1 to $2"
  else
    fail "could not link $1 to $2"
  fi
}

# Check which system we are on
DOTFILE_SYSTEM_TYPE=${DOTFILE_SYSTEM_TYPE:-}

if [ -z "$DOTFILE_SYSTEM_TYPE" ] && [ -n "${CODESPACES:-}" ]; then
  DOTFILE_SYSTEM_TYPE="codespaces"
fi

if [ -z "$DOTFILE_SYSTEM_TYPE" ] && [ "$(uname -s)" == "Darwin" ]; then
  DOTFILE_SYSTEM_TYPE="macos"
fi

# Old bp-dev URLs
if [ -z "$DOTFILE_SYSTEM_TYPE" ] && hostname | grep -q "bpdev-us-east-1.github.net"; then
  DOTFILE_SYSTEM_TYPE="bpdev"
fi

# New bp-dev URLs
if [ -z "$DOTFILE_SYSTEM_TYPE" ] && hostname | grep -q "jcambass-.*\.octoca\.ts\.net"; then
  DOTFILE_SYSTEM_TYPE="bpdev"
fi

if [ -z "$DOTFILE_SYSTEM_TYPE" ]; then
  fail "Could not determine dotfile system type. Set DOTFILE_SYSTEM_TYPE to macos, codespaces, or bpdev."
fi

DOTFILES_SYSTEM_MANIFEST="$DOTFILES_ROOT/systems/$DOTFILE_SYSTEM_TYPE"
if [ ! -f "$DOTFILES_SYSTEM_MANIFEST" ]; then
  fail "Missing system manifest: $DOTFILES_SYSTEM_MANIFEST"
fi

# write out the system type to a file
echo "$DOTFILE_SYSTEM_TYPE" > "$DOTFILES_ROOT/.system"

# Default values for the conflict resolution. Bootstrap is non-interactive:
# skip conflicts unless explicitly told to overwrite or back them up.
overwrite_all=false backup_all=false

if [ -n "${DOTFILES_OVERWRITE_CONFLICTS}" ]; then overwrite_all=true; fi
if [ -n "${DOTFILES_BACKUP_CONFLICTS}" ]; then backup_all=true; fi

manifest_topic_dirs () {
  local topic

  while IFS= read -r topic || [ -n "$topic" ]
  do
    topic="${topic%%#*}"
    topic="${topic#"${topic%%[![:space:]]*}"}"
    topic="${topic%"${topic##*[![:space:]]}"}"

    if [ -z "$topic" ]; then
      continue
    fi

    if [ ! -d "$DOTFILES_ROOT/$topic" ]; then
      fail "Manifest topic does not exist: $topic"
    fi

    printf '%s\n' "$DOTFILES_ROOT/$topic"
  done < "$DOTFILES_SYSTEM_MANIFEST"
}

# Link all the files that should go into our home directory
linked_any=false
while IFS= read -r topic_dir
do
  while IFS= read -r -d '' src
  do
    linked_any=true
    dst="$HOME/.$(basename "${src%.*}")"
    link_file "$src" "$dst"
  done < <(find -H "$topic_dir" -maxdepth 2 -name '*.symlink' -print0)
done < <(manifest_topic_dirs)

if [ "$linked_any" = "false" ]; then
  info "No .symlink files found to link."
fi

# Perform all install scripts
if [ -n "${DOTFILES_SKIP_INSTALLS:-}" ]; then
  info "Skipping install.sh files because DOTFILES_SKIP_INSTALLS is set."
  print_summary
  exit 0
fi

installed_any=false
install_failures=0
while IFS= read -r topic_dir
do
  while IFS= read -r -d '' src
  do
    installed_any=true
    if DOTFILES_ROOT="$DOTFILES_ROOT" DOTFILE_SYSTEM_TYPE="$DOTFILE_SYSTEM_TYPE" bash "$src"; then
      install_count=$((install_count + 1))
      success "ran $src"
    else
      install_failures=$((install_failures + 1))
      fail "install script failed: $src"
    fi
  done < <(find -H "$topic_dir" -maxdepth 2 -name 'install.sh' -print0)
done < <(manifest_topic_dirs)

if [ "$installed_any" = "false" ]; then
  info "No install.sh files found to execute."
fi

print_summary
